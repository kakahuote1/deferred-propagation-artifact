  "activeSemanticScope": {
    "name": "event_handoff_shape_invariance",
    "outputTag": "event_handoff_shape_invariance",
    "activeLayers": ["mechanism_benchmark", "boundary_control"],
    "rationale": [
      "Hold event/capture semantics constant and perturb only the carrier and handoff form.",
      "Measure robustness under semantic-preserving rewrites instead of treating the corpus as a head-to-head benchmark.",
      "Keep source shape, sink shape, payload, resume, builtin packs, and engine plugins fixed."
    ],
    "fixedFactors": {
      "payload": ["none"],
      "capture": ["capture_in"],
      "resume": ["none"],
      "trigger": ["event", "call"]
    },
    "deferredFocus": ["event"],
    "controlRows": ["call"],
    "excludedForNow": [
      "Promise/await payload-resume rows stay in the dedicated async semantic corpus.",
      "Blind holdout and natural-sample layers are not part of this perturbation scope."
    ]
  },
  "twinRules": [
    "Each twin group must contain exactly one positive case and one negative case.",
    "Twin cases must share the same semantic factors; only taint consumption at the sink may differ.",
    "Perturbation variants under the same semantic family must preserve the same semantic intent while changing only surface handoff form."
  ],
